  "docs": {
    "brief": "brief.md",
    "spec": "spec.md",
    "eval": "eval.md",
    "readme": "README.md",
    "changelog": "changelog.md"
  },
  "assets": {
    "cover": "assets/screenshots/cover.png"
  },
  "commands": {
    "dev": "pnpm --filter weather-market dev",
    "build": "pnpm --filter weather-market build",
    "test": "pnpm --filter weather-market test"
  }
}
