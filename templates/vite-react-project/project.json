{
  "id": "template-project",
  "name": "Template Project",
  "status": "prototype",
  "type": "webapp",
  "runtime": "static-artifact",
  "summary": "Template project.",
  "tags": ["prototype"],
  "projectRoot": "projects/template-project",
  "entry": {
    "kind": "iframe",
    "path": "/runs/template-project/index.html"
  },
  "docs": {
    "brief": "brief.md",
    "spec": "spec.md",
    "eval": "eval.md",
    "readme": "README.md",
    "changelog": "changelog.md"
  },
  "assets": {
    "cover": "assets/screenshots/cover.png"
  },
  "commands": {
    "dev": "pnpm --filter template-project dev",
    "build": "pnpm --filter template-project build",
    "test": "pnpm --filter template-project test"
  }
}
